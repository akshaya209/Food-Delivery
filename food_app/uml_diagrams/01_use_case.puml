@startuml Use Case Diagram
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor white
skinparam ArrowColor #333333
skinparam ActorBorderColor #333333
skinparam UsecaseBorderColor #4A90D9
skinparam UsecaseBackgroundColor #EBF4FF

actor Customer
actor Admin
actor Driver

rectangle "Online Food Ordering System" {
    usecase "Register / Login" as UC1
    usecase "Browse Restaurants" as UC2
    usecase "Search Restaurant" as UC3
    usecase "View Menu" as UC4
    usecase "Add to Cart" as UC5
    usecase "Apply Coupon" as UC6
    usecase "Place Order" as UC7
    usecase "Make Payment" as UC8
    usecase "Track Order" as UC9
    usecase "Write Review" as UC10
    usecase "Update Profile" as UC11

    usecase "Manage Restaurants" as UC12
    usecase "Manage Menu Items" as UC13
    usecase "View All Orders" as UC14
    usecase "Update Order Status" as UC15
}

Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4
Customer --> UC5
Customer --> UC6
Customer --> UC7
Customer --> UC8
Customer --> UC9
Customer --> UC10
Customer --> UC11

Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC1

UC3 .> UC2 : <<extends>>
UC6 .> UC7 : <<includes>>
UC8 .> UC7 : <<includes>>

@enduml
